# Secrets ONLY. Copy to .env and fill in. NEVER commit .env (it is gitignored).
# Non-secret config (models, urls, caps) lives in config.toml, not here.

# Ollama API key.
#   - Local daemon: any value works, use "ollama".
#   - Ollama Cloud (https://ollama.com/v1): real key from ollama.com/settings/keys.
OLLAMA_API_KEY=ollama

# Secret used to sign session cookies. Generate one for production:
#   python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=dev-insecure-change-me

# ----- VPS / public deployment (all optional locally) -----

# Public domain. When set, start.sh enables Caddy on 80/443 with automatic HTTPS.
# DOMAIN=chat.example.com

# Serve session cookies only over HTTPS (set when DOMAIN is used).
# AUTH__COOKIE_SECURE=true

# Chat/vision/coding straight to Ollama Cloud:
# OLLAMA__BASE_URL=https://ollama.com/v1

# Embeddings from the local CPU appliance (Ollama Cloud has no embedding models).
# When this points at //ollama:11434, start.sh enables the appliance + pulls the model.
# OLLAMA__EMBED_BASE_URL=http://ollama:11434/v1
