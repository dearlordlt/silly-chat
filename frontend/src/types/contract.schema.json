{
  "$defs": {
    "AgentStatusEvent": {
      "description": "Working heartbeat to fill dead air during multi-round-trip runs.",
      "properties": {
        "event": {
          "const": "agent_status",
          "default": "agent_status",
          "title": "Event",
          "type": "string"
        },
        "message": {
          "title": "Message",
          "type": "string"
        }
      },
      "required": [
        "message"
      ],
      "title": "AgentStatusEvent",
      "type": "object"
    },
    "AgentUpdateEvent": {
      "description": "Lifecycle of an individual sub-agent \u2014 drives the live activity panel.\n\nThe frontend merges by ``id``: ``label`` is set when the agent starts; later\nupdates carry ``status``/``state`` only.",
      "properties": {
        "event": {
          "const": "agent_update",
          "default": "agent_update",
          "title": "Event",
          "type": "string"
        },
        "id": {
          "title": "Id",
          "type": "string"
        },
        "label": {
          "default": "",
          "title": "Label",
          "type": "string"
        },
        "status": {
          "default": "",
          "title": "Status",
          "type": "string"
        },
        "state": {
          "default": "running",
          "enum": [
            "running",
            "done",
            "error"
          ],
          "title": "State",
          "type": "string"
        }
      },
      "required": [
        "id"
      ],
      "title": "AgentUpdateEvent",
      "type": "object"
    },
    "BlockDataEvent": {
      "description": "Fills a previously-started block with its validated payload.",
      "properties": {
        "event": {
          "const": "block_data",
          "default": "block_data",
          "title": "Event",
          "type": "string"
        },
        "block_id": {
          "title": "Block Id",
          "type": "string"
        },
        "block": {
          "discriminator": {
            "mapping": {
              "change": "#/$defs/ChangeBlock",
              "chart": "#/$defs/ChartBlock",
              "code": "#/$defs/CodeBlock",
              "diagram": "#/$defs/DiagramBlock",
              "edits": "#/$defs/EditsBlock",
              "file": "#/$defs/FileBlock",
              "gallery": "#/$defs/GalleryBlock",
              "map": "#/$defs/MapBlock",
              "sim": "#/$defs/SimBlock",
              "slides": "#/$defs/SlidesBlock",
              "sources": "#/$defs/SourcesBlock",
              "table": "#/$defs/TableBlock",
              "text": "#/$defs/TextBlock",
              "timeline": "#/$defs/TimelineBlock"
            },
            "propertyName": "type"
          },
          "oneOf": [
            {
              "$ref": "#/$defs/TextBlock"
            },
            {
              "$ref": "#/$defs/TableBlock"
            },
            {
              "$ref": "#/$defs/GalleryBlock"
            },
            {
              "$ref": "#/$defs/ChartBlock"
            },
            {
              "$ref": "#/$defs/SimBlock"
            },
            {
              "$ref": "#/$defs/TimelineBlock"
            },
            {
              "$ref": "#/$defs/ChangeBlock"
            },
            {
              "$ref": "#/$defs/CodeBlock"
            },
            {
              "$ref": "#/$defs/DiagramBlock"
            },
            {
              "$ref": "#/$defs/SlidesBlock"
            },
            {
              "$ref": "#/$defs/EditsBlock"
            },
            {
              "$ref": "#/$defs/FileBlock"
            },
            {
              "$ref": "#/$defs/MapBlock"
            },
            {
              "$ref": "#/$defs/SourcesBlock"
            }
          ],
          "title": "Block"
        }
      },
      "required": [
        "block_id",
        "block"
      ],
      "title": "BlockDataEvent",
      "type": "object"
    },
    "BlockStartEvent": {
      "description": "Opens a block. Carries the type (and id) BEFORE any data \u2014 enables skeleton.",
      "properties": {
        "event": {
          "const": "block_start",
          "default": "block_start",
          "title": "Event",
          "type": "string"
        },
        "block_id": {
          "title": "Block Id",
          "type": "string"
        },
        "block_type": {
          "title": "Block Type",
          "type": "string"
        }
      },
      "required": [
        "block_id",
        "block_type"
      ],
      "title": "BlockStartEvent",
      "type": "object"
    },
    "ChangeBlock": {
      "description": "How a value shifts across segments over time \u2014 e.g. opinion by age group\nper year, adoption per demographic.\n\n``data[period][group][option]`` is the value cube. With several options the\nUI shows 100%-stacked bars per group (with per-period tabs and deltas) plus\na trend view of ``trend_option`` over the periods; with a single option the\nbars scale against the largest value instead.",
      "properties": {
        "type": {
          "const": "change",
          "default": "change",
          "title": "Type",
          "type": "string"
        },
        "title": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Title"
        },
        "subtitle": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "e.g. 'By age group \u00b7 2023\u20132026 \u00b7 % of respondents'.",
          "title": "Subtitle"
        },
        "periods": {
          "description": "Time points, e.g. ['2023','2024'].",
          "items": {
            "type": "string"
          },
          "maxItems": 12,
          "minItems": 2,
          "title": "Periods",
          "type": "array"
        },
        "groups": {
          "description": "Segments, e.g. age groups.",
          "items": {
            "type": "string"
          },
          "maxItems": 8,
          "minItems": 1,
          "title": "Groups",
          "type": "array"
        },
        "options": {
          "description": "Answer categories, e.g. ['Support','Neutral','Oppose']; one entry for a plain metric.",
          "items": {
            "type": "string"
          },
          "maxItems": 5,
          "minItems": 1,
          "title": "Options",
          "type": "array"
        },
        "data": {
          "description": "data[period][group][option] \u2014 same order as the label lists.",
          "items": {
            "items": {
              "items": {
                "type": "number"
              },
              "type": "array"
            },
            "type": "array"
          },
          "title": "Data",
          "type": "array"
        },
        "trend_option": {
          "default": 0,
          "description": "Index into options that the trend view plots.",
          "title": "Trend Option",
          "type": "integer"
        },
        "unit": {
          "default": "%",
          "description": "Value unit shown in labels.",
          "title": "Unit",
          "type": "string"
        }
      },
      "required": [
        "periods",
        "groups",
        "options",
        "data"
      ],
      "title": "ChangeBlock",
      "type": "object"
    },
    "ChartBlock": {
      "properties": {
        "type": {
          "const": "chart",
          "default": "chart",
          "title": "Type",
          "type": "string"
        },
        "kind": {
          "enum": [
            "bar",
            "line",
            "area",
            "pie",
            "donut"
          ],
          "title": "Kind",
          "type": "string"
        },
        "labels": {
          "items": {
            "type": "string"
          },
          "title": "Labels",
          "type": "array"
        },
        "values": {
          "description": "Values for a single series (one per label).",
          "items": {
            "type": "number"
          },
          "title": "Values",
          "type": "array"
        },
        "series": {
          "anyOf": [
            {
              "items": {
                "$ref": "#/$defs/ChartSeries"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "For comparisons: several named series (each one value per label); rendered with a legend.",
          "title": "Series"
        },
        "title": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Title"
        }
      },
      "required": [
        "kind",
        "labels"
      ],
      "title": "ChartBlock",
      "type": "object"
    },
    "ChartSeries": {
      "properties": {
        "name": {
          "title": "Name",
          "type": "string"
        },
        "values": {
          "items": {
            "type": "number"
          },
          "title": "Values",
          "type": "array"
        }
      },
      "required": [
        "name",
        "values"
      ],
      "title": "ChartSeries",
      "type": "object"
    },
    "CodeBlock": {
      "properties": {
        "type": {
          "const": "code",
          "default": "code",
          "title": "Type",
          "type": "string"
        },
        "language": {
          "title": "Language",
          "type": "string"
        },
        "content": {
          "title": "Content",
          "type": "string"
        },
        "filename": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Relative path/name when the code is a real file (enables download).",
          "title": "Filename"
        },
        "artifact_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Stable id of the code artifact this block is the latest version of.",
          "title": "Artifact Id"
        }
      },
      "required": [
        "language",
        "content"
      ],
      "title": "CodeBlock",
      "type": "object"
    },
    "DiagramBlock": {
      "description": "A Mermaid diagram authored by the model (flowcharts, sequences, ER, etc.).",
      "properties": {
        "type": {
          "const": "diagram",
          "default": "diagram",
          "title": "Type",
          "type": "string"
        },
        "mermaid": {
          "description": "Valid Mermaid source, e.g. 'graph TD; A-->B'.",
          "title": "Mermaid",
          "type": "string"
        },
        "title": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Title"
        }
      },
      "required": [
        "mermaid"
      ],
      "title": "DiagramBlock",
      "type": "object"
    },
    "DoneEvent": {
      "properties": {
        "event": {
          "const": "done",
          "default": "done",
          "title": "Event",
          "type": "string"
        },
        "input_tokens": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Input Tokens"
        },
        "output_tokens": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Output Tokens"
        },
        "context_window": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Context Window"
        },
        "models": {
          "items": {
            "type": "string"
          },
          "title": "Models",
          "type": "array"
        }
      },
      "title": "DoneEvent",
      "type": "object"
    },
    "EditChange": {
      "description": "One applied search/replace hunk \u2014 enough to render a familiar diff.",
      "properties": {
        "old": {
          "title": "Old",
          "type": "string"
        },
        "new": {
          "title": "New",
          "type": "string"
        }
      },
      "required": [
        "old",
        "new"
      ],
      "title": "EditChange",
      "type": "object"
    },
    "EditsBlock": {
      "description": "The changes applied to a code artifact this turn (targeted edit).\n\nTool-authored only \u2014 produced when write_code patches an artifact in place,\nso the transcript keeps a readable record of what changed and the canvas\nshows the result.",
      "properties": {
        "type": {
          "const": "edits",
          "default": "edits",
          "title": "Type",
          "type": "string"
        },
        "artifact_id": {
          "title": "Artifact Id",
          "type": "string"
        },
        "name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Name"
        },
        "changes": {
          "items": {
            "$ref": "#/$defs/EditChange"
          },
          "title": "Changes",
          "type": "array"
        }
      },
      "required": [
        "artifact_id",
        "changes"
      ],
      "title": "EditsBlock",
      "type": "object"
    },
    "ErrorEvent": {
      "properties": {
        "event": {
          "const": "error",
          "default": "error",
          "title": "Event",
          "type": "string"
        },
        "message": {
          "title": "Message",
          "type": "string"
        }
      },
      "required": [
        "message"
      ],
      "title": "ErrorEvent",
      "type": "object"
    },
    "FileBlock": {
      "description": "A downloadable generated file (e.g. a PDF from make_document).\n\nTool-authored only \u2014 the url points into the uploads store (owner-only).",
      "properties": {
        "type": {
          "const": "file",
          "default": "file",
          "title": "Type",
          "type": "string"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "url": {
          "title": "Url",
          "type": "string"
        },
        "mime": {
          "default": "application/octet-stream",
          "title": "Mime",
          "type": "string"
        },
        "size": {
          "default": 0,
          "title": "Size",
          "type": "integer"
        }
      },
      "required": [
        "name",
        "url"
      ],
      "title": "FileBlock",
      "type": "object"
    },
    "GalleryBlock": {
      "properties": {
        "type": {
          "const": "gallery",
          "default": "gallery",
          "title": "Type",
          "type": "string"
        },
        "images": {
          "items": {
            "$ref": "#/$defs/GalleryImage"
          },
          "title": "Images",
          "type": "array"
        }
      },
      "required": [
        "images"
      ],
      "title": "GalleryBlock",
      "type": "object"
    },
    "GalleryImage": {
      "properties": {
        "url": {
          "title": "Url",
          "type": "string"
        },
        "caption": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Caption"
        },
        "source_url": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Page the image was found on, for attribution.",
          "title": "Source Url"
        }
      },
      "required": [
        "url"
      ],
      "title": "GalleryImage",
      "type": "object"
    },
    "ImageQuotaEvent": {
      "description": "Emitted after an image generation when the user's weekly quota runs low\n(\u226410% left) \u2014 the client shows a quiet, dismissable toast. Never sent while\nplenty of quota remains: limits stay invisible until they matter.",
      "properties": {
        "event": {
          "const": "image_quota",
          "default": "image_quota",
          "title": "Event",
          "type": "string"
        },
        "used": {
          "title": "Used",
          "type": "integer"
        },
        "remaining": {
          "title": "Remaining",
          "type": "integer"
        },
        "resets_at": {
          "title": "Resets At",
          "type": "string"
        }
      },
      "required": [
        "used",
        "remaining",
        "resets_at"
      ],
      "title": "ImageQuotaEvent",
      "type": "object"
    },
    "MapArea": {
      "description": "A shaded region on the map: a real OSM boundary, or an LLM-sketched\napproximation (drawn dashed + labeled approximate).",
      "properties": {
        "name": {
          "title": "Name",
          "type": "string"
        },
        "approximate": {
          "default": false,
          "title": "Approximate",
          "type": "boolean"
        },
        "polygons": {
          "items": {
            "items": {
              "items": {
                "type": "number"
              },
              "type": "array"
            },
            "type": "array"
          },
          "title": "Polygons",
          "type": "array"
        }
      },
      "required": [
        "name",
        "polygons"
      ],
      "title": "MapArea",
      "type": "object"
    },
    "MapBlock": {
      "description": "A map with resolved locations (and optionally a route between them).\n\nNever authored by the model directly \u2014 the ``show_map`` tool geocodes real\ncoordinates and records this block, so positions can't be hallucinated.",
      "properties": {
        "type": {
          "const": "map",
          "default": "map",
          "title": "Type",
          "type": "string"
        },
        "points": {
          "items": {
            "$ref": "#/$defs/MapPoint"
          },
          "title": "Points",
          "type": "array"
        },
        "route": {
          "anyOf": [
            {
              "$ref": "#/$defs/MapRoute"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "areas": {
          "anyOf": [
            {
              "items": {
                "$ref": "#/$defs/MapArea"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Areas"
        },
        "title": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Title"
        }
      },
      "required": [
        "points"
      ],
      "title": "MapBlock",
      "type": "object"
    },
    "MapLeg": {
      "description": "One leg of a multi-modal route (e.g. a walk, then Bus 3).",
      "properties": {
        "mode": {
          "title": "Mode",
          "type": "string"
        },
        "label": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Label"
        },
        "geometry": {
          "items": {
            "items": {
              "type": "number"
            },
            "type": "array"
          },
          "title": "Geometry",
          "type": "array"
        }
      },
      "required": [
        "mode",
        "geometry"
      ],
      "title": "MapLeg",
      "type": "object"
    },
    "MapPoint": {
      "properties": {
        "name": {
          "title": "Name",
          "type": "string"
        },
        "lat": {
          "title": "Lat",
          "type": "number"
        },
        "lon": {
          "title": "Lon",
          "type": "number"
        }
      },
      "required": [
        "name",
        "lat",
        "lon"
      ],
      "title": "MapPoint",
      "type": "object"
    },
    "MapRoute": {
      "properties": {
        "distance_km": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Distance Km"
        },
        "duration_min": {
          "title": "Duration Min",
          "type": "number"
        },
        "mode": {
          "default": "car",
          "enum": [
            "car",
            "bike",
            "foot",
            "transit"
          ],
          "title": "Mode",
          "type": "string"
        },
        "geometry": {
          "items": {
            "items": {
              "type": "number"
            },
            "type": "array"
          },
          "title": "Geometry",
          "type": "array"
        },
        "legs": {
          "anyOf": [
            {
              "items": {
                "$ref": "#/$defs/MapLeg"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Legs"
        }
      },
      "required": [
        "duration_min",
        "geometry"
      ],
      "title": "MapRoute",
      "type": "object"
    },
    "Reply": {
      "description": "The orchestrator's final structured answer.",
      "properties": {
        "blocks": {
          "items": {
            "discriminator": {
              "mapping": {
                "change": "#/$defs/ChangeBlock",
                "chart": "#/$defs/ChartBlock",
                "code": "#/$defs/CodeBlock",
                "diagram": "#/$defs/DiagramBlock",
                "gallery": "#/$defs/GalleryBlock",
                "sim": "#/$defs/SimBlock",
                "slides": "#/$defs/SlidesBlock",
                "sources": "#/$defs/SourcesBlock",
                "table": "#/$defs/TableBlock",
                "text": "#/$defs/TextBlock",
                "timeline": "#/$defs/TimelineBlock"
              },
              "propertyName": "type"
            },
            "oneOf": [
              {
                "$ref": "#/$defs/TextBlock"
              },
              {
                "$ref": "#/$defs/TableBlock"
              },
              {
                "$ref": "#/$defs/GalleryBlock"
              },
              {
                "$ref": "#/$defs/ChartBlock"
              },
              {
                "$ref": "#/$defs/SimBlock"
              },
              {
                "$ref": "#/$defs/TimelineBlock"
              },
              {
                "$ref": "#/$defs/ChangeBlock"
              },
              {
                "$ref": "#/$defs/CodeBlock"
              },
              {
                "$ref": "#/$defs/DiagramBlock"
              },
              {
                "$ref": "#/$defs/SlidesBlock"
              },
              {
                "$ref": "#/$defs/SourcesBlock"
              }
            ]
          },
          "title": "Blocks",
          "type": "array"
        }
      },
      "required": [
        "blocks"
      ],
      "title": "Reply",
      "type": "object"
    },
    "SimAxis": {
      "description": "The input domain the curves are sampled over.",
      "properties": {
        "label": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Label"
        },
        "min": {
          "title": "Min",
          "type": "number"
        },
        "max": {
          "title": "Max",
          "type": "number"
        },
        "unit": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Unit"
        },
        "step": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
